classDiagram
    %% ── 异常层次 ──
    class AppException {
        +str message
        +int code
        +int status_code
    }
    class NotFoundException {
        +__init__(message, code=404)
    }
    class ValidationException {
        +__init__(message, code=422)
    }
    class AuthException {
        +__init__(message, code=401)
    }
    class BusinessException {
        +__init__(message, code=1)
    }
    class ServiceUnavailableException {
        +__init__(message, code=503)
    }
    AppException <|-- NotFoundException
    AppException <|-- ValidationException
    AppException <|-- AuthException
    AppException <|-- BusinessException
    AppException <|-- ServiceUnavailableException

    %% ── 响应辅助 ──
    class ResponseHelpers {
        +success_response(data, message) dict
        +paginated_response(items, total, page, page_size) dict
        +error_response(code, message, data) dict
    }

    %% ── Service 基类 ──
    class BaseService {
        +AsyncSession db
        +__init__(db)
    }

    %% ── 业务 Service ──
    class AuthService {
        +register(username, password) User
        +authenticate(username, password) dict
        +get_user(user_id) User
    }
    class DetectionService {
        +YOLOService yolo_service
        +LLMService llm_service
        +ImageService image_service
        +process_image_detection(...) dict
    }
    class YOLOService {
        +detect(image_path, model_path) list
        +pre_download_models()
    }
    class LLMService {
        +analyze_image(...) dict
        +chat_completion(...) str
    }
    class ImageService {
        +encode_image_base64(path) str
        +generate_thumbnail(content) str
    }
    class VideoService {
        +extract_frames(video_path, interval) list
        +generate_annotated_video(...) str
    }
    class DashboardService {
        +get_stats(user_id) dict
    }
    class HistoryService {
        +list_records(user_id, filters) dict
        +get_record(record_id) DetectionRecord
        +delete_record(record_id)
    }
    class LLMConfigService {
        +create(user_id, data) LLMConfig
        +list(user_id) list
        +update(config_id, data) LLMConfig
        +delete(config_id)
        +test_connection(config_id) dict
    }

    BaseService <|-- AuthService
    BaseService <|-- DetectionService
    BaseService <|-- YOLOService
    BaseService <|-- LLMService
    BaseService <|-- ImageService
    BaseService <|-- VideoService
    BaseService <|-- DashboardService
    BaseService <|-- HistoryService
    BaseService <|-- LLMConfigService

    %% ── TaskQueue 与处理器 ──
    class TaskQueue {
        -Semaphore _semaphore
        -bool _running
        +start()
        +stop()
        -_process_loop()
        -_dispatch(db, record)
    }
    class ImageProcessor {
        +process(record)
    }
    class VideoProcessor {
        +process(record)
    }
    class FrameAnalysisProcessor {
        +process(record)
    }
    class CameraProcessor {
        +process(record)
    }
    TaskQueue --> ImageProcessor : dispatches to
    TaskQueue --> VideoProcessor : dispatches to
    TaskQueue --> FrameAnalysisProcessor : dispatches to
    TaskQueue --> CameraProcessor : dispatches to

    %% ── 配置模块 ──
    class Settings {
        +DatabaseSettings
        +RedisSettings
        +AuthSettings
        +UploadSettings
        +YOLOSettings
        +LLMSettings
        +ServerSettings
    }
    class DatabaseSettings {
        +MYSQL_HOST
        +MYSQL_PORT
        +DATABASE_URL
    }
    class RedisSettings {
        +REDIS_HOST
        +REDIS_PORT
    }
    class AuthSettings {
        +SECRET_KEY
        +JWT_ALGORITHM
    }
    class UploadSettings {
        +UPLOAD_DIR
        +MAX_IMAGE_SIZE_MB
    }
    class YOLOSettings {
        +YOLO_DEFAULT_MODEL
        +YOLO_DEVICE
    }
    class LLMSettings {
        +LLM_TIMEOUT_SECONDS
    }
    class ServerSettings {
        +BACKEND_HOST
        +CORS_ORIGINS
    }

    Settings *-- DatabaseSettings
    Settings *-- RedisSettings
    Settings *-- AuthSettings
    Settings *-- UploadSettings
    Settings *-- YOLOSettings
    Settings *-- LLMSettings
    Settings *-- ServerSettings
