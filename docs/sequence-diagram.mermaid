sequenceDiagram
    actor User
    participant API as DetectionRouter
    participant Resp as ResponseHelpers
    participant Auth as get_current_user
    participant DS as DetectionService
    participant DB as AsyncSession
    participant YOLO as YOLOService
    participant LLM as LLMService
    participant Img as ImageService
    participant TQ as TaskQueue
    participant VP as VideoProcessor

    %% ── 图片检测流程 ──
    rect rgb(240, 248, 255)
        Note over User,Img: 图片检测（同步）

        User->>API: POST /api/detection/detect
        API->>Auth: 验证 JWT Token
        Auth-->>API: current_user

        API->>DS: DetectionService(db)
        DS->>DS: process_image_detection(user_id, image, mode, model_id, llm_config_id)

        alt mode == "yolo_only"
            DS->>YOLO: detect(image_path, model_path)
            YOLO-->>DS: bboxes[]
        else mode == "llm_only"
            DS->>Img: encode_image_base64(image_path)
            Img-->>DS: base64_string
            DS->>LLM: analyze_image(api_url, api_key, model, image_b64, prompt)
            LLM-->>DS: llm_analysis
        else mode == "collaborative"
            DS->>YOLO: detect(image_path, model_path)
            YOLO-->>DS: bboxes[]
            DS->>Img: encode_image_base64(image_path)
            Img-->>DS: base64_string
            DS->>LLM: analyze_image(api_url, api_key, model, image_b64, prompt)
            LLM-->>DS: llm_analysis
        end

        DS->>Img: generate_thumbnail(content)
        Img-->>DS: thumbnail_path

        DS->>DB: add(DetectionRecord)
        DS->>DB: commit()

        DS-->>API: result dict

        API->>Resp: success_response(data=result)
        Resp-->>API: {"code":0, "message":"ok", "data":{...}}
        API-->>User: 200 JSON Response
    end

    %% ── 任务队列流程 ──
    rect rgb(255, 248, 240)
        Note over User,VP: 视频检测（异步任务队列）

        User->>API: POST /api/tasks (video upload)
        API->>Auth: 验证 JWT Token
        Auth-->>API: current_user

        API->>DB: add(DetectionRecord, status="pending")
        API->>DB: commit()
        DB-->>API: record

        API->>Resp: success_response(data={task_id, status:"pending"})
        API-->>User: 200 JSON Response

        Note over TQ: 后台 _process_loop 轮询

        loop 每 1 秒轮询
            TQ->>DB: SELECT ... WHERE status="pending" ... FOR UPDATE SKIP LOCKED
            DB-->>TQ: record (or None)
        end

        TQ->>DB: UPDATE status="running"
        TQ->>DB: commit()

        TQ->>TQ: _dispatch(db, record)

        alt source_type == "video" && mode in ("llm_only","collaborative")
            TQ->>VP: process(record)
            VP->>VP: 逐帧 YOLO 检测 + LLM 分析
            loop 每处理一帧
                VP->>DB: UPDATE progress
                VP->>DB: commit()
            end
            VP-->>TQ: done
        else source_type == "video"
            TQ->>VP: process(record)
            VP->>VP: 逐帧 YOLO 检测
            VP-->>TQ: done
        else source_type == "image"
            TQ->>DS: process_image_detection(...)
            DS-->>TQ: result
        end

        TQ->>DB: UPDATE status="completed", result_json=..., progress=100
        TQ->>DB: commit()

        User->>API: GET /api/tasks/{id}
        API->>DB: SELECT DetectionRecord WHERE id=...
        DB-->>API: record (status="completed")
        API->>Resp: success_response(data=record)
        API-->>User: 200 JSON Response
    end

    %% ── 异常处理流程 ──
    rect rgb(255, 240, 240)
        Note over User,API: 异常处理流程

        User->>API: GET /api/models/999
        API->>DB: SELECT YOLOModel WHERE id=999
        DB-->>API: None

        API->>API: raise NotFoundException("YOLO模型不存在")
        Note over API: 全局异常处理器捕获

        API-->>User: 404 {"code":404, "message":"YOLO模型不存在", "data":null}
    end
